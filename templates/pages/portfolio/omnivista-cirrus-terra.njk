{% extends "layout.njk" %}
{% set pageTitle = "Khopa | OmniVista Cirrus & Terra" %}
{% set description = "Case study for OmniVista Cirrus and Terra, cloud and on-prem network management platforms." %}
{% set bodyClass = "page-main" %}

{% block mainContent %}
<div class="container project-case">
  <section class="page-hero" data-reveal>
    <p class="eyebrow">Portfolio</p>
    <h1>OmniVista Cirrus &amp; Terra</h1>
    <p>Cloud and on-prem network management platforms for enterprise infrastructure.</p>
  </section>

  <section class="project-hero-card" data-reveal>
    <div class="project-summary">
      <p class="eyebrow">Network Management</p>
      <h2>Operating at the core of enterprise networking</h2>
      <p>
        OmniVista Cirrus and Terra are management platforms for ALE network equipment, covering cloud and on-prem deployment models.
      </p>
      <p>
        This work spanned backend services, data processing, performance tuning, database optimization, security follow-up, and later leadership responsibilities on the broader platform and product area.
      </p>
      <ul class="project-facts">
        <li>Networking</li>
        <li>Cloud</li>
        <li>On-Prem</li>
        <li>Platform Engineering</li>
      </ul>
    </div>

    <div class="project-cover">
      <div class="project-cover__media">
        <img src="../assets/images/portfolio/bigdata.png" alt="Network management platform visualization">
      </div>
      <p class="project-cover__caption">Platform-oriented work across telemetry, infrastructure, backend services, and deployment models.</p>
    </div>
  </section>

  <section class="project-panel" data-reveal>
    <p class="eyebrow">My Work</p>
    <h2>From backend engineering to product leadership</h2>
    <p>
      I contributed first as a cloud software engineer, focusing on backend data-processing services, performance improvements, query optimization, maintenance, and security remediation.
    </p>
    <p>
      Over time, the scope expanded into architecture and delivery decisions, team leadership, and finally broader R&amp;D responsibilities around the network product line.
    </p>
    <div class="project-links">
      <a class="button button--secondary" href="./index.html">Back to portfolio</a>
    </div>
  </section>
</div>
{% endblock %}